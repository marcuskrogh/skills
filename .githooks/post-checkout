#!/bin/sh
# Auto-sync skills to local agent skill dirs after git checkout (branch switch).
REPO_ROOT="$(git rev-parse --show-toplevel)"
case "$REPO_ROOT" in
  *cursor-skills*|*/skills) ;;
  *) exit 0 ;;
esac

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File "$REPO_ROOT/scripts/sync-local.ps1" -Prune
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File "$REPO_ROOT/scripts/sync-local.ps1" -Prune
fi
